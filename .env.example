# =============================================================================
# .env.example — Portfolio Lead-to-Cash Pipeline
# Copie para .env e ajuste conforme necessario.
# NUNCA commite o .env real com credenciais reais.
# =============================================================================

# ─── PostgreSQL (Data Warehouse) ──────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=data_warehouse
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin

# ─── Mock API ─────────────────────────────────────────────────────────────────
# URLs apontam para o mock_api container dentro da rede Docker
META_API_URL=http://mock_api:8000
KOMMO_API_URL=http://mock_api:8000

# ─── Mock: Meta Ads ───────────────────────────────────────────────────────────
META_ACCESS_TOKEN=mock_token_portfolio_meta
META_ACCOUNT_ID=123456789

# ─── Mock: Kommo CRM ──────────────────────────────────────────────────────────
KOMMO_TOKEN=mock_token_portfolio_kommo

# ─── Apache Airflow ───────────────────────────────────────────────────────────
# UID do usuario no host (necessario para permissoes corretas nos volumes)
# No Linux: execute `echo -e "AIRFLOW_UID=$(id -u)" >> .env`
# No Mac/Windows com Docker Desktop: o valor padrao 50000 funciona
AIRFLOW_UID=50000

# Chave Fernet para criptografar conexoes salvas no banco do Airflow.
# Gere uma nova com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANTE: altere este valor em ambientes compartilhados ou de producao.
AIRFLOW_FERNET_KEY=JexE3D_iG0RPkfBNf4K1X9bSWDJ__8L_nZ9gCi5CQPM=

# Chave secreta do Webserver (para assinar sessoes e tokens JWT)
AIRFLOW_SECRET_KEY=portfolio-secret-change-in-prod
